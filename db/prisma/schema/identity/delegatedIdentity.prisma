enum DelegatedIdentityCredentialStatus {
  active
  revoked
}

model DelegatedIdentityCredential {
  oid BigInt @id
  id  String @unique

  permissions IdentityDelegationPermissions[]
  status      DelegatedIdentityCredentialStatus

  credentialOid BigInt
  credential    IdentityCredential @relation(fields: [credentialOid], references: [oid], onDelete: Cascade)

  actorOid BigInt
  actor    IdentityActor @relation(fields: [actorOid], references: [oid], onDelete: Cascade)

  createdAt                           DateTime                            @default(now())
  delegatedIdentityCredentialsUpdates DelegatedIdentityCredentialUpdate[]
}

model DelegatedIdentityCredentialUpdate {
  oid BigInt @id
  id  String @unique

  delegatedCredentialsOid BigInt
  delegatedCredentials    DelegatedIdentityCredential @relation(fields: [delegatedCredentialsOid], references: [oid], onDelete: Cascade)

  responsibleDelegationOid BigInt
  responsibleDelegation    IdentityDelegation @relation(fields: [responsibleDelegationOid], references: [oid], onDelete: Cascade)

  statusBefore DelegatedIdentityCredentialStatus
  statusAfter  DelegatedIdentityCredentialStatus

  permissionsBefore IdentityDelegationPermissions[]
  permissionsAfter  IdentityDelegationPermissions[]

  createdAt DateTime @default(now())
}
