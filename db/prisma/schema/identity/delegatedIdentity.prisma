enum DelegatedIdentityStatus {
  active
  revoked
}

model DelegatedIdentity {
  oid BigInt @id
  id  String @unique

  permissions IdentityDelegationPermissions[]
  status      DelegatedIdentityStatus

  identityOid BigInt
  identity    Identity @relation(fields: [identityOid], references: [oid], onDelete: Cascade)

  actorOid BigInt
  actor    IdentityActor @relation(fields: [actorOid], references: [oid], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  expiresAt DateTime?

  credentials              DelegatedIdentityCredential[]
  delegatedIdentityUpdates DelegatedIdentityUpdate[]

  @@unique([identityOid, actorOid])
}

model DelegatedIdentityCredential {
  oid BigInt @id
  id  String @unique

  isActive Boolean

  permissions IdentityDelegationPermissions[]
  status      DelegatedIdentityStatus

  delegatedIdentityOid BigInt
  delegatedIdentity    DelegatedIdentity @relation(fields: [delegatedIdentityOid], references: [oid], onDelete: Cascade)

  credentialOid BigInt
  credential    IdentityCredential @relation(fields: [credentialOid], references: [oid], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  expiresAt DateTime?

  delegatedIdentityCredentialUpdates DelegatedIdentityCredentialUpdate[]

  @@unique([delegatedIdentityOid, credentialOid])
}

model DelegatedIdentityUpdate {
  oid BigInt @id
  id  String @unique

  delegatedIdentityOid BigInt
  delegatedIdentity    DelegatedIdentity @relation(fields: [delegatedIdentityOid], references: [oid], onDelete: Cascade)

  statusBefore DelegatedIdentityStatus
  statusAfter  DelegatedIdentityStatus

  permissionsBefore IdentityDelegationPermissions[]
  permissionsAfter  IdentityDelegationPermissions[]

  expiresAtBefore DateTime?
  expiresAtAfter  DateTime?

  createdAt                          DateTime                            @default(now())
  delegatedIdentityCredentialUpdates DelegatedIdentityCredentialUpdate[]
}

model DelegatedIdentityCredentialUpdate {
  oid BigInt @id
  id  String @unique

  updateOid BigInt
  update    DelegatedIdentityUpdate @relation(fields: [updateOid], references: [oid], onDelete: Cascade)

  delegatedCredentialOid BigInt
  delegatedCredential    DelegatedIdentityCredential @relation(fields: [delegatedCredentialOid], references: [oid], onDelete: Cascade)

  statusBefore DelegatedIdentityStatus
  statusAfter  DelegatedIdentityStatus

  expiresAtBefore DateTime?
  expiresAtAfter  DateTime?

  permissionsBefore IdentityDelegationPermissions[]
  permissionsAfter  IdentityDelegationPermissions[]

  createdAt DateTime @default(now())
}
