enum IdentityActorType {
  person
  agent
}

enum IdentityActorStatus {
  active
  archived
  deleted
}

model IdentityActor {
  oid BigInt @id
  id  String @unique

  type            IdentityActorType
  status          IdentityActorStatus
  isParentDeleted Boolean             @default(false)

  name        String
  description String?
  metadata    Json?

  tenantOid BigInt
  tenant    Tenant @relation(fields: [tenantOid], references: [oid], onDelete: Cascade)

  environmentOid BigInt
  environment    Environment @relation(fields: [environmentOid], references: [oid], onDelete: Cascade)

  solutionOid Int
  solution    Solution @relation(fields: [solutionOid], references: [oid], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  agent                       Agent?
  identities                  Identity[]
  identityDelegationParties   IdentityDelegationParty[]
  delegatedIdentityCredential DelegatedIdentityCredential[]
  identityDelegationRequests  IdentityDelegationRequest[]
}
